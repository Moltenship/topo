{
  "name": "@molten-voice/desktop",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "electron-vite dev",
    "start": "electron-vite preview",
    "typecheck": "tsgo --project tsconfig.json --noEmit",
    "fmt": "oxfmt --check electron renderer/src electron.vite.config.ts package.json tsconfig.json",
    "lint": "oxlint .",
    "test": "vitest run --passWithNoTests",
    "rebuild:native": "electron-rebuild -f -w better-sqlite3",
    "build": "electron-vite build"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@molten-voice/asr": "workspace:*",
    "@molten-voice/audio": "workspace:*",
    "@molten-voice/db": "workspace:*",
    "@molten-voice/model-catalog": "workspace:*",
    "@molten-voice/native-bridge": "workspace:*",
    "@molten-voice/shared": "workspace:*",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/vite": "^4.2.4",
    "@tanstack/react-router": "^1.139.3",
    "@vitejs/plugin-react": "^5.1.2",
    "better-sqlite3": "12.9.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "effect": "^3.19.11",
    "electron": "^39.2.7",
    "electron-vite": "^5.0.0",
    "lucide-react": "^1.14.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "vite": "^8.0.11"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3"
  }
}
