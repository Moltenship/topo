    "react-dom": "^19.2.3",
    "react-resizable-panels": "^4.11.0",
    "recharts": "3.8.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "vaul": "^1.1.2",
    "vite": "^8.0.11"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@electron/rebuild": "^4.0.4",
    "@rolldown/plugin-babel": "^0.2.3",
    "@types/react": "^19.2.7",
