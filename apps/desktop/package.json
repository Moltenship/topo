    "@tanstack/react-router": "^1.139.3",
    "@topo/asr": "workspace:*",
    "@topo/audio": "workspace:*",
    "@topo/contracts": "workspace:*",
    "@topo/db": "workspace:*",
    "@topo/model-catalog": "workspace:*",
    "@topo/native-bridge": "workspace:*",
    "@topo/shared": "workspace:*",
    "@vitejs/plugin-react": "^6.0.2",
    "better-sqlite3": "12.9.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "effect": "^3.19.11",
    "electron": "^39.2.7",
    "electron-vite": "^5.0.0",
    "embla-carousel-react": "^8.6.0",
